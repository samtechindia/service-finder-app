# Database Configuration
# Copy this file to .env and replace with your actual values

# PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.cmjpwawlcyoteoiaytci.supabase.co:5432/postgres"

# Alternative: Connection pooling (port 6543) - recommended for production
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.cmjpwawlcyoteoiaytci.supabase.co:6543/postgres?pgbouncer=true"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
NODE_ENV="development"
PORT="3001"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"
